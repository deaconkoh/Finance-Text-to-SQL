  "employees": {
    "id": {
      "description": "Primary key for each employee record.",
      "semantic_role": "primary_key",
      "measure_type": "identifier",
      "grounding_level": "schema_direct"
    },
    "businessID": {
      "description": "Business identifier linking the employee to a business.",
      "semantic_role": "foreign_key",
      "measure_type": "identifier",
      "grounding_level": "foreign_key"
    },
    "Employee_name": {
      "description": "Employee name.",
      "semantic_role": "entity_identifier",
      "entity_scope": "employee",
      "domain_object": "employee",
      "measure_type": "identifier",
      "unit": "text",
      "grounding_level": "schema_direct"
    },
    "Employee_ID": {
      "description": "Internal employee identifier code.",
      "semantic_role": "entity_identifier",
      "entity_scope": "employee",
      "domain_object": "employee",
      "measure_type": "identifier",
      "unit": "text",
      "grounding_level": "schema_direct"
    },
    "Hire_date": {
      "description": "Date the employee was hired.",
      "semantic_role": "entity_date",
      "entity_scope": "employee",
      "measure_type": "date",
      "unit": "date",
      "time_behavior": "employee_lifecycle_date",
      "grounding_level": "schema_direct",
      "use_for": ["employee tenure and hire-date filters"]
    },
    "Billing_rate": {
      "description": "Employee billing rate field, but observed data contains only missing placeholder values.",
      "semantic_role": "rate_measure",
      "entity_scope": "employee",
      "measure_type": "rate",
      "unit": "monetary_per_unit",
      "data_availability": "placeholder_only",
      "usable_as_measure": false,
      "value_concepts": {
        "--": "missing"
      },
      "missing_value_policy": {
        "meaning": "missing_or_unavailable",
        "do_not_use_for_numeric_computation": true
      },
      "invalid_value_policy": "unobserved_literal_warning",
      "grounding_level": "observed_data_plus_schema_name",
      "grounding_rule": "Although the column name suggests a billing rate, the observed dataset only contains '--', so it should not be treated as a usable numeric measure."
    },
    "Deleted": {
      "description": "Soft-delete status flag for an employee record.",
      "semantic_role": "status_flag",
      "entity_scope": "employee",
      "status_dimension": "record_status",
      "measure_type": "categorical",
      "unit": "status_label",
      "value_concepts": {
        "yes": "deleted",
        "no": "active"
      },
      "invalid_value_policy": "unobserved_literal_warning",
      "grounding_level": "observed_data_plus_schema_direct",
      "grounding_rule": "Deleted is a record-status flag. Only observed literals should be mapped to status concepts."
    }
  },
  "master_txn_table": {
    "id": {
      "description": "Primary key for each transaction-line record.",
      "semantic_role": "primary_key",
      "measure_type": "identifier",
      "grounding_level": "schema_direct"
    },
    "businessID": {
      "description": "Business identifier linking the transaction line to a business.",
      "semantic_role": "foreign_key",
      "measure_type": "identifier",
      "grounding_level": "foreign_key"
    },
    "Transaction_ID": {
      "description": "Identifier grouping multiple transaction lines into one business transaction.",
      "semantic_role": "transaction_group_identifier",
      "entity_scope": "transaction",
      "domain_object": "transaction",
      "measure_type": "identifier",
      "unit": "id",
      "groups_rows": true,
      "table_grain": "transaction_line",
      "balance_rule": "sum(Debit) should equal sum(Credit) within a transaction group.",
      "grounding_level": "schema_direct",
      "grounding_rule": "Transaction_ID groups line-level debit and credit postings."
    },
    "Transaction_DATE": {
      "description": "Date on which the underlying economic transaction occurred.",
      "semantic_role": "transaction_date",
      "entity_scope": "transaction",
      "measure_type": "date",
      "unit": "date",
      "time_behavior": "economic_event_date",
      "grounding_level": "schema_direct",
      "use_for": [
        "financial period filtering",
        "revenue period",
        "expense period",
        "transaction period"
      ],
      "not_for": ["system creation date filtering"]
    },
    "Transaction_TYPE": {
      "description": "Observed transaction type label for each transaction line.",
      "semantic_role": "transaction_type_classifier",
      "entity_scope": "transaction",
      "measure_type": "categorical",
      "domain_object": "transaction_type",
      "unit": "label",
      "value_concepts": {
        "invoice": "invoice",
        "bill": "bill",
        "deposit": "deposit"
      },
      "concept_metadata": {
        "invoice": {
          "transaction_family": "customer_sales_or_receivable_transaction",
          "related_party_role": "customer",
          "related_entity_column": "Customers",
          "related_status_column": "AR_paid",
          "related_domain_object": "accounts_receivable"
        },
        "bill": {
          "transaction_family": "vendor_purchase_or_payable_transaction",
          "related_party_role": "vendor",
          "related_entity_column": "Vendor",
          "related_status_column": "AP_paid",
          "related_domain_object": "accounts_payable"
        },
        "deposit": {
          "transaction_family": "cash_or_bank_movement",
          "related_domain_object": "deposit"
        }
      },
      "question_aliases": {
        "customer invoice": "invoice",
        "sales invoice": "invoice",
        "invoice transaction": "invoice",
        "sales": "invoice",
        "sale": "invoice",
        "vendor bill": "bill",
        "supplier bill": "bill",
        "payable bill": "bill",
        "purchase bill": "bill",
        "bank deposit": "deposit",
        "cash deposit": "deposit",
        "deposit transaction": "deposit"
      },
      "invalid_value_policy": "unobserved_literal_warning",
      "literal_match_policy": "case_sensitive_exact_match_preferred",
      "grounding_level": "observed_data_plus_schema_direct",
      "grounding_rule": "Transaction_TYPE is a categorical transaction classifier. value_concepts contains only observed SQLite literals. Natural-language alternatives are stored separately as question_aliases."
    },
    "Amount": {
      "description": "Gross transaction amount without explicit debit or credit posting side.",
      "semantic_role": "financial_measure",
      "entity_scope": "transaction",
      "domain_object": "gross_transaction_amount",
      "measure_type": "flow",
      "financial_element": "context_dependent",
      "sign_convention": "ambiguous",
      "normal_balance": "ambiguous",
      "posting_side": "not_applicable",
      "unit": "monetary",
      "time_behavior": "transaction_level",
      "requires_account_context": true,
      "warning": "Amount does not encode debit or credit direction.",
      "grounding_level": "schema_direct"
    },
    "CreatedDATE": {
      "description": "System date when the transaction record was created.",
      "semantic_role": "system_created_date",
      "entity_scope": "transaction",
      "measure_type": "date",
      "unit": "date",
      "time_behavior": "system_timestamp",
      "grounding_level": "schema_direct",
      "use_for": ["record creation filtering", "audit filtering"],
      "not_for": [
        "financial period filtering",
        "revenue period filtering",
        "expense period filtering"
      ]
    },
    "CreatedUSER": {
      "description": "User who created the transaction record.",
      "semantic_role": "audit_user",
      "entity_scope": "audit",
      "domain_object": "audit_metadata",
      "measure_type": "categorical",
      "unit": "text",
      "grounding_level": "schema_direct"
    },
    "Account": {
      "description": "Ledger account name posted on this transaction line.",
      "semantic_role": "account_identifier",
      "entity_scope": "account",
      "domain_object": "ledger_account",
      "measure_type": "identifier",
      "unit": "text",
      "linked_table": "chart_of_accounts",
      "linked_column": "Account_name",
      "classification_column": "chart_of_accounts.Account_type",
      "grounding_level": "foreign_key",
      "grounding_rule": "Account identifies the ledger posting account; Account_type provides the financial statement element."
    },
    "AR_paid": {
      "description": "Accounts receivable settlement status flag.",
      "semantic_role": "settlement_status_flag",
      "status_dimension": "payment_status",
      "entity_scope": "transaction_line",
      "domain_object": "accounts_receivable",
      "related_party_role": "customer",
      "related_entity_column": "Customers",
      "related_account": "accounts receivable (a/r)",
      "related_measure": "Open_balance",
      "measure_type": "categorical",
      "financial_element": "asset",
      "unit": "status_label",
      "value_concepts": {
        "paid": "paid"
      },
      "missing_value_policy": {
        "missing_markers": ["--", "", "null"],
        "meaning": "missing_or_not_applicable",
        "do_not_map_directly_to": "unpaid",
        "requires_context": true
      },
      "invalid_value_policy": "unobserved_literal_warning",
      "grounding_level": "observed_data_profile",
      "grounding_rule": "AR_paid is a receivable settlement status field. Only observed literals should be mapped to payment concepts.",
      "related_normal_balance": "debit"
    },
    "AP_paid": {
      "description": "Accounts payable settlement status flag.",
      "semantic_role": "settlement_status_flag",
      "status_dimension": "payment_status",
      "entity_scope": "transaction_line",
      "domain_object": "accounts_payable",
      "related_party_role": "vendor",
      "related_entity_column": "Vendor",
      "related_account": "accounts payable (a/p)",
      "related_measure": "Open_balance",
      "measure_type": "categorical",
      "financial_element": "liability",
      "unit": "status_label",
      "value_concepts": {
        "paid": "paid"
      },
      "missing_value_policy": {
        "missing_markers": ["--", "", "null"],
        "meaning": "missing_or_not_applicable",
        "do_not_map_directly_to": "unpaid",
        "requires_context": true
      },
      "invalid_value_policy": "unobserved_literal_warning",
      "grounding_level": "observed_data_profile",
      "grounding_rule": "AP_paid is a payable settlement status field. Only observed literals should be mapped to payment concepts.",
      "related_normal_balance": "credit"
    },
    "Due_DATE": {
      "description": "Payment due date for the transaction.",
      "semantic_role": "due_date",
      "entity_scope": "transaction",
      "measure_type": "date",
      "unit": "date",
      "time_behavior": "settlement_due_date",
      "grounding_level": "schema_direct",
      "use_for": ["due-date filtering", "overdue analysis", "aging analysis"],
      "not_for": [
        "transaction occurrence date",
        "revenue period filtering",
        "expense period filtering"
      ]
    },
    "Open_balance": {
      "description": "Remaining unsettled amount for a transaction line.",
      "semantic_role": "financial_measure",
      "entity_scope": "transaction_line",
      "domain_object": "outstanding_transaction_balance",
      "measure_type": "stock",
      "financial_element": "context_dependent",
      "sign_convention": "context_dependent",
      "normal_balance": "context_dependent",
      "unit": "monetary",
      "time_behavior": "point_in_time",
      "context_rules": [
        {
          "if_status_column": "AR_paid",
          "then_domain_object": "accounts_receivable",
          "then_related_party_role": "customer",
          "then_financial_element": "asset",
          "then_normal_balance": "debit"
        },
        {
          "if_status_column": "AP_paid",
          "then_domain_object": "accounts_payable",
          "then_related_party_role": "vendor",
          "then_financial_element": "liability",
          "then_normal_balance": "credit"
        }
      ],
      "grounding_level": "schema_inferred",
      "grounding_rule": "Open balance is a remaining unsettled stock amount; AR/AP context determines whether it is receivable or payable."
    },
    "Customers": {
      "description": "Customer name associated with the transaction line.",
      "semantic_role": "entity_identifier",
      "entity_scope": "customer",
      "domain_object": "customer",
      "measure_type": "identifier",
      "unit": "text",
      "grounding_level": "schema_direct",
      "linked_table": "customers",
      "linked_column": "customer_name",
      "related_financial_object": "accounts_receivable"
    },
    "Vendor": {
      "description": "Vendor name associated with the transaction line.",
      "semantic_role": "entity_identifier",
      "entity_scope": "vendor",
      "domain_object": "vendor",
      "measure_type": "identifier",
      "unit": "text",
      "grounding_level": "schema_direct",
      "linked_table": "vendors",
      "linked_column": "Vendor_name",
      "related_financial_object": "accounts_payable"
    },
    "Product_Service": {
      "description": "Product or service line item associated with the transaction line.",
      "semantic_role": "product_service_identifier",
      "entity_scope": "product_service",
      "domain_object": "product_or_service",
      "measure_type": "identifier",
      "unit": "text",
      "linked_table": "products",
      "linked_column": "Product_Service",
      "warning": "Product_Service is not an account classifier. Account-level questions should use Account or Account_type, not Product_Service.",
      "grounding_level": "foreign_key"
    },
    "Quantity": {
      "description": "Number of units for the product or service on the transaction line.",
      "semantic_role": "quantity_measure",
      "entity_scope": "transaction_line",
      "domain_object": "line_item_quantity",
      "measure_type": "quantity",
      "unit": "count",
      "time_behavior": "transaction_level",
      "grounding_level": "schema_direct"
    },
    "Rate": {
      "description": "Unit price or rate applied to the product or service on the transaction line.",
      "semantic_role": "rate_measure",
      "entity_scope": "transaction_line",
