{
  "__schema_metadata__": {
    "version": "booksql_financial_semantics_v4_clean",
    "design_principle": "Column annotations provide compact, schema-grounded financial semantics. SQL literal mappings are stored once in column-level value_concepts; natural-language aliases stay separate from SQL values.",
    "grounding_levels": [
      "schema_direct",
      "foreign_key",
      "observed_data_profile",
      "bookkeeping_rule",
      "schema_inferred"
    ],
    "table_metadata": {
      "master_txn_table": {
        "table_grain": "transaction_line",
        "transaction_group_key": "Transaction_ID",
        "balancing_rule": "Debit and Credit postings within the same transaction group are expected to balance in double-entry accounting.",
        "count_star_warning": "COUNT(*) counts transaction lines, not necessarily distinct transactions or invoices."
      }
    },
    "bookkeeping_rules": {
      "posting_effect_rules": {
        "asset": {
          "normal_balance": "debit",
          "debit_effect": "increase",
          "credit_effect": "decrease"
        },
        "expense": {
          "normal_balance": "debit",
          "debit_effect": "increase",
          "credit_effect": "decrease"
        },
        "liability": {
          "normal_balance": "credit",
          "debit_effect": "decrease",
          "credit_effect": "increase"
        },
        "equity": {
          "normal_balance": "credit",
          "debit_effect": "decrease",
          "credit_effect": "increase"
        },
        "income": {
          "normal_balance": "credit",
          "debit_effect": "decrease",
          "credit_effect": "increase"
        }
      }
    }
  },
  "chart_of_accounts": {
