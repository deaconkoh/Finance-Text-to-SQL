      "measure_type": "categorical",
      "unit": "text",
      "financial_element": "classified_by_value",
      "normal_balance": "classified_by_value",
      "value_concepts": {
        "accounts payable (a/p)": "accounts_payable",
        "accounts receivable (a/r)": "accounts_receivable",
        "bank": "cash_or_bank",
        "credit card": "credit_card_payable",
        "equity": "equity",
        "expenses": "expense",
        "fixed assets": "fixed_asset",
        "income": "income",
        "long term liabilities": "long_term_liability",
        "other current assets": "current_asset",
        "other current liabilities": "current_liability",
        "other expense": "expense",
        "other income": "income"
      },
      "concept_metadata": {
        "accounts_receivable": {
          "financial_element": "asset",
          "normal_balance": "debit_normal",
          "domain_object": "accounts_receivable"
        },
        "accounts_payable": {
          "financial_element": "liability",
          "normal_balance": "credit_normal",
          "domain_object": "accounts_payable"
        },
        "cash_or_bank": {
          "financial_element": "asset",
          "normal_balance": "debit_normal",
          "domain_object": "cash_or_bank_account"
        },
        "credit_card_payable": {
          "financial_element": "liability",
          "normal_balance": "credit_normal",
          "domain_object": "credit_card_payable"
        },
        "equity": {
          "financial_element": "equity",
          "normal_balance": "credit_normal",
          "domain_object": "equity"
        },
        "expense": {
          "financial_element": "expense",
          "normal_balance": "debit_normal",
          "domain_object": "expense"
        },
        "fixed_asset": {
          "financial_element": "asset",
          "normal_balance": "debit_normal",
          "domain_object": "fixed_asset"
        },
        "income": {
          "financial_element": "income",
          "normal_balance": "credit_normal",
          "domain_object": "income"
        },
        "long_term_liability": {
          "financial_element": "liability",
          "normal_balance": "credit_normal",
          "domain_object": "long_term_liability"
        },
        "current_asset": {
          "financial_element": "asset",
          "normal_balance": "debit_normal",
          "domain_object": "current_asset"
        },
        "current_liability": {
          "financial_element": "liability",
          "normal_balance": "credit_normal",
          "domain_object": "current_liability"
        }
      },
      "question_aliases": {
        "accounts payable": "accounts_payable",
        "a/p": "accounts_payable",
        "payable": "accounts_payable",
        "payables": "accounts_payable",
        "vendor payable": "accounts_payable",
        "accounts receivable": "accounts_receivable",
        "a/r": "accounts_receivable",
        "receivable": "accounts_receivable",
        "receivables": "accounts_receivable",
        "customer receivable": "accounts_receivable",
        "asset": "asset",
        "assets": "asset",
        "bank account": "cash_or_bank",
        "cash": "cash_or_bank",
        "cash account": "cash_or_bank",
        "credit card liability": "credit_card_payable",
        "credit card payable": "credit_card_payable",
        "capital": "equity",
        "owner equity": "equity",
        "owner's equity": "equity",
        "cost": "expense",
        "costs": "expense",
        "expense": "expense",
        "expenses": "expense",
        "cogs": "expense",
        "cost of goods sold": "expense",
        "fixed asset": "fixed_asset",
        "fixed assets": "fixed_asset",
        "revenue": "income",
        "revenues": "income",
        "sales": "income",
        "income": "income",
        "earnings": "income",
        "long term liability": "long_term_liability",
        "long-term liability": "long_term_liability",
        "current asset": "current_asset",
        "current liability": "current_liability"
      },
      "invalid_value_policy": "unobserved_literal_warning",
      "grounding_level": "observed_chart_of_accounts_plus_bookkeeping_rule",
      "grounding_rule": "Account_type literals are restricted to values observed in chart_of_account_OB.csv. Financial element and normal balance are derived from standard double-entry bookkeeping rules."
    }
  },
